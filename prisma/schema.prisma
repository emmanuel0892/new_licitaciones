generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  lastname      String
  rut           String    @unique
  email         String    @unique
  password      String
  typeAccount   String    @map("type_account")
  departamento  String
  active        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  licitaciones         Licitacion[]
  documentosLicitacion DocumentoLicitacion[]
  historialLicitacion  HistorialLicitacion[]

  @@map("users")
}

model FormatoLiquidacion {
  id           Int          @id @default(autoincrement())
  titulo       String
  cantidadPasos Int         @map("cantidad_pasos")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  licitaciones Licitacion[]
  procesos     ProcesoLicitacion[]

  @@map("formato_liquidacion")
}

model ProcesoLicitacion {
  id                    Int                @id @default(autoincrement())
  formatoLiquidacionId  Int                @map("fk_formato_liquidacion_id")
  tituloProceso         String             @map("titulo_proceso")
  turno                 String
  numeroPaso            Int                @map("numero_paso")
  diasSugeridos         Int                @default(5) @map("dias_sugeridos")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  formatoLiquidacion    FormatoLiquidacion @relation(fields: [formatoLiquidacionId], references: [id])
  licitaciones          Licitacion[]

  @@map("proceso_licitacion")
}

model Licitacion {
  id                    Int                @id @default(autoincrement())
  formatoLiquidacionId  Int                @map("fk_formato_liquidacion_id")
  usuarioId             String             @map("fk_usuario_id")
  procesoActualId       Int                @map("fk_proceso_actual_id")
  requirente            String
  numeroLicitacion      String?            @map("numero_licitacion")
  vigencia              DateTime?
  nombreLicitacion      String             @map("nombre_licitacion")
  montoPresupuestado    String?            @map("monto_presupuestado")
  estado                String             @default("Pendiente")
  contadorDevoluciones  Int                @default(0) @map("contador_devoluciones")
  contadorEdiciones     Int                @default(0) @map("contador_ediciones")
  fechaRecepcion        DateTime?          @map("fecha_recepcion")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  formatoLiquidacion    FormatoLiquidacion @relation(fields: [formatoLiquidacionId], references: [id])
  usuario               User               @relation(fields: [usuarioId], references: [id])
  procesoActual         ProcesoLicitacion  @relation(fields: [procesoActualId], references: [id])
  documentos            DocumentoLicitacion[]
  historial             HistorialLicitacion[]

  @@map("licitaciones")
}

model DocumentoLicitacion {
  id            Int        @id @default(autoincrement())
  licitacionId  Int        @map("fk_licitacion_id")
  usuarioId     String     @map("fk_usuario_id")
  nombreArchivo String     @map("nombre_archivo")
  rutaArchivo   String     @map("ruta_archivo")
  createdAt     DateTime   @default(now()) @map("created_at")

  licitacion    Licitacion @relation(fields: [licitacionId], references: [id])
  usuario       User       @relation(fields: [usuarioId], references: [id])

  @@map("documentos_licitacion")
}

model HistorialLicitacion {
  id            Int        @id @default(autoincrement())
  licitacionId  Int        @map("fk_licitacion_id")
  usuarioId     String     @map("fk_usuario_id")
  tipoAccion    String     @map("tipo_accion")
  procesoOrigen String?    @map("proceso_origen")
  procesoDestino String?   @map("proceso_destino")
  observacion   String?
  createdAt     DateTime   @default(now()) @map("created_at")

  licitacion    Licitacion @relation(fields: [licitacionId], references: [id])
  usuario       User       @relation(fields: [usuarioId], references: [id])

  @@map("historial_licitacion")
}

model Requirente {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("requirentes")
}

model PAC {
  id             Int      @id @default(autoincrement())
  servicio       String
  supraServicio  String   @map("supra_servicio")
  bodega         String
  codigo         String
  detalle        String
  unidadMedida   String   @map("unidad_medida")
  costoUnitario  Float    @map("costo_unitario")
  cantidadAnual  Int      @map("cantidad_anual")
  enero          Int      @default(0)
  febrero        Int      @default(0)
  marzo          Int      @default(0)
  abril          Int      @default(0)
  mayo           Int      @default(0)
  junio          Int      @default(0)
  julio          Int      @default(0)
  agosto         Int      @default(0)
  septiembre     Int      @default(0)
  octubre        Int      @default(0)
  noviembre      Int      @default(0)
  diciembre      Int      @default(0)
  mensual        Float    @default(0)
  anoPac         String   @map("ano_pac")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("pac")
}

model RequerimientoAbastecimiento {
  id              Int      @id @default(autoincrement())
  titulo          String
  descripcion     String?
  estado          String   @default("Pendiente")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  productos       ProductoRequerimiento[]
  historial       HistorialRequerimiento[]

  @@map("requerimiento_abastecimiento")
}

model ProductoRequerimiento {
  id                Int                        @id @default(autoincrement())
  requerimientoId   Int                        @map("fk_requerimiento_id")
  nombreProducto    String                     @map("nombre_producto")
  cantidad          Int
  stock             Int                        @default(0)
  cantidadProgramada Int                       @default(0) @map("cantidad_programada")
  createdAt         DateTime                   @default(now()) @map("created_at")

  requerimiento     RequerimientoAbastecimiento @relation(fields: [requerimientoId], references: [id])

  @@map("producto_requerimiento")
}

model HistorialRequerimiento {
  id              Int                        @id @default(autoincrement())
  requerimientoId Int                        @map("fk_requerimiento_id")
  accion          String
  descripcion     String?
  createdAt       DateTime                   @default(now()) @map("created_at")

  requerimiento   RequerimientoAbastecimiento @relation(fields: [requerimientoId], references: [id])

  @@map("historial_requerimiento")
}

model Novedad {
  id          Int      @id @default(autoincrement())
  titular     String
  descripcion String
  imagen      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("novedades")
}

model FormatoBase {
  id         Int      @id @default(autoincrement())
  titulo     String
  tipoBase   String   @map("tipo_base")
  documento  String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("formato_bases")
}

// ========================================
// SEGUIMIENTO DE CONSUMO - MERCADO PÚBLICO
// ========================================

model LicitacionMP {
  id                    Int       @id @default(autoincrement())
  codigoExterno         String    @unique @map("codigo_externo")
  nombre                String
  descripcion           String?   @db.Text
  estado                String
  codigoEstado          Int       @map("codigo_estado")
  tipo                  String
  codigoTipo            Int?      @map("codigo_tipo")
  moneda                String?   @default("CLP")
  etapas                Int?      @default(1)
  modalidad             Int?      @default(1)
  montoEstimado         Float?    @map("monto_estimado")
  montoAdjudicado       Float?    @map("monto_adjudicado")
  tiempoDuracion        String?   @map("tiempo_duracion")
  unidadTiempoDuracion  Int?      @map("unidad_tiempo_duracion")
  
  // Fechas
  fechaCreacion         DateTime? @map("fecha_creacion_mp")
  fechaPublicacion      DateTime? @map("fecha_publicacion")
  fechaCierre           DateTime? @map("fecha_cierre")
  fechaAdjudicacion     DateTime? @map("fecha_adjudicacion")
  fechaInicio           DateTime? @map("fecha_inicio")
  fechaFinal            DateTime? @map("fecha_final")
  
  // Adjudicación
  adjudicacionTipo      Int?      @map("adjudicacion_tipo")
  adjudicacionNumero    String?   @map("adjudicacion_numero")
  adjudicacionNumOferentes Int?   @map("adjudicacion_num_oferentes")
  adjudicacionUrlActa   String?   @map("adjudicacion_url_acta") @db.Text
  
  // Comprador
  codigoOrganismo       String?   @map("codigo_organismo")
  nombreOrganismo       String?   @map("nombre_organismo")
  rutUnidad             String?   @map("rut_unidad")
  codigoUnidad          String?   @map("codigo_unidad")
  nombreUnidad          String?   @map("nombre_unidad")
  direccionUnidad       String?   @map("direccion_unidad")
  comunaUnidad          String?   @map("comuna_unidad")
  regionUnidad          String?   @map("region_unidad")
  nombreUsuario         String?   @map("nombre_usuario")
  cargoUsuario          String?   @map("cargo_usuario")
  
  // Campos locales de seguimiento
  requirente            String
  vigenciaMeses         Int?      @map("vigencia_meses")
  montoConsumido        Float     @default(0) @map("monto_consumido")
  porcentajeConsumo     Float     @default(0) @map("porcentaje_consumo")
  alertaEnviada50       Boolean   @default(false) @map("alerta_enviada_50")
  alertaEnviada75       Boolean   @default(false) @map("alerta_enviada_75")
  alertaEnviada90       Boolean   @default(false) @map("alerta_enviada_90")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  items                 ItemLicitacionMP[]
  ordenesCompra         OrdenCompraMP[]
  alertas               AlertaConsumo[]

  @@map("licitaciones_mp")
}

model ItemLicitacionMP {
  id                Int           @id @default(autoincrement())
  licitacionMPId    Int           @map("fk_licitacion_mp_id")
  correlativo       Int
  codigoProducto    Int           @map("codigo_producto")
  codigoCategoria   String        @map("codigo_categoria")
  categoria         String?       @db.Text
  nombreProducto    String        @map("nombre_producto")
  descripcion       String?       @db.Text
  unidadMedida      String        @map("unidad_medida")
  cantidadTotal     Float         @map("cantidad_total")
  cantidadAdjudicada Float?       @map("cantidad_adjudicada")
  cantidadConsumida Float         @default(0) @map("cantidad_consumida")
  montoUnitario     Float         @map("monto_unitario")
  montoTotal        Float         @map("monto_total")
  rutProveedor      String?       @map("rut_proveedor")
  nombreProveedor   String?       @map("nombre_proveedor")
  createdAt         DateTime      @default(now()) @map("created_at")

  licitacionMP      LicitacionMP  @relation(fields: [licitacionMPId], references: [id], onDelete: Cascade)
  itemsOrden        ItemOrdenCompraMP[]

  @@map("items_licitacion_mp")
}

model OrdenCompraMP {
  id                  Int           @id @default(autoincrement())
  licitacionMPId      Int?          @map("fk_licitacion_mp_id")
  codigoLicitacion    String?       @map("codigo_licitacion")
  codigo              String        @unique
  nombre              String
  descripcion         String?       @db.Text
  codigoEstado        Int           @map("codigo_estado")
  estado              String
  codigoTipo          String?       @map("codigo_tipo")
  tipo                String
  tipoMoneda          String?       @default("CLP") @map("tipo_moneda")
  
  // Estados proveedor
  codigoEstadoProveedor Int?        @map("codigo_estado_proveedor")
  estadoProveedor     String?       @map("estado_proveedor")
  
  // Montos
  descuentos          Float         @default(0)
  cargos              Float         @default(0)
  totalNeto           Float         @map("total_neto")
  porcentajeIva       Float?        @default(19) @map("porcentaje_iva")
  impuestos           Float
  total               Float
  
  // Fechas
  fechaCreacion       DateTime      @map("fecha_creacion")
  fechaEnvio          DateTime?     @map("fecha_envio")
  fechaAceptacion     DateTime?     @map("fecha_aceptacion")
  fechaCancelacion    DateTime?     @map("fecha_cancelacion")
  fechaUltimaModificacion DateTime? @map("fecha_ultima_modificacion")
  
  // Otros
  financiamiento      String?
  tipoDespacho        String?       @map("tipo_despacho")
  formaPago           String?       @map("forma_pago")
  
  // Comprador
  codigoOrganismo     String?       @map("codigo_organismo")
  nombreOrganismo     String?       @map("nombre_organismo")
  rutUnidad           String?       @map("rut_unidad")
  nombreUnidad        String?       @map("nombre_unidad")
  direccionUnidad     String?       @map("direccion_unidad")
  comunaUnidad        String?       @map("comuna_unidad")
  nombreContacto      String?       @map("nombre_contacto")
  cargoContacto       String?       @map("cargo_contacto")
  
  // Proveedor
  codigoProveedor     String?       @map("codigo_proveedor")
  rutProveedor        String?       @map("rut_proveedor")
  nombreProveedor     String?       @map("nombre_proveedor")
  direccionProveedor  String?       @map("direccion_proveedor")
  comunaProveedor     String?       @map("comuna_proveedor")
  regionProveedor     String?       @map("region_proveedor")
  
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  licitacionMP        LicitacionMP? @relation(fields: [licitacionMPId], references: [id], onDelete: SetNull)
  items               ItemOrdenCompraMP[]

  @@map("ordenes_compra_mp")
}

model ItemOrdenCompraMP {
  id                    Int             @id @default(autoincrement())
  ordenCompraId         Int             @map("fk_orden_compra_id")
  itemLicitacionMPId    Int?            @map("fk_item_licitacion_mp_id")
  correlativo           Int
  codigoCategoria       Int             @map("codigo_categoria")
  categoria             String?         @db.Text
  codigoProducto        Int             @map("codigo_producto")
  producto              String
  especificacionComprador String?       @map("especificacion_comprador") @db.Text
  especificacionProveedor String?       @map("especificacion_proveedor") @db.Text
  cantidad              Float
  unidad                String?
  moneda                String?         @default("CLP")
  precioNeto            Float           @map("precio_neto")
  totalDescuentos       Float           @default(0) @map("total_descuentos")
  totalCargos           Float           @default(0) @map("total_cargos")
  totalImpuestos        Float           @default(0) @map("total_impuestos")
  total                 Float
  createdAt             DateTime        @default(now()) @map("created_at")

  ordenCompra           OrdenCompraMP   @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  itemLicitacion        ItemLicitacionMP? @relation(fields: [itemLicitacionMPId], references: [id])

  @@map("items_orden_compra_mp")
}

model AlertaConsumo {
  id              Int           @id @default(autoincrement())
  licitacionMPId  Int           @map("fk_licitacion_mp_id")
  tipo            String
  porcentaje      Float
  mensaje         String        @db.Text
  leida           Boolean       @default(false)
  createdAt       DateTime      @default(now()) @map("created_at")

  licitacionMP    LicitacionMP  @relation(fields: [licitacionMPId], references: [id], onDelete: Cascade)

  @@map("alertas_consumo")
}
